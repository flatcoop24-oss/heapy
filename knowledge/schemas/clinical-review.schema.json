{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heapy.local/schemas/clinical-review.schema.json",
  "title": "Clinical Review Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_id",
    "capability_id",
    "review_scope",
    "required_reviewer_roles",
    "reviewer_refs",
    "policy_ids",
    "evidence_ids",
    "evaluation_case_ids",
    "decision",
    "decision_rationale",
    "protocol_version",
    "evidence_version",
    "decision_at",
    "valid_from",
    "valid_until",
    "version",
    "status"
  ],
  "properties": {
    "review_id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
    "capability_id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
    "review_scope": {"type": "string", "minLength": 1},
    "required_reviewer_roles": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "reviewer_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "policy_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}, "uniqueItems": true},
    "evidence_ids": {"type": "array", "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}, "uniqueItems": true},
    "evaluation_case_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}, "uniqueItems": true},
    "decision": {"enum": ["PENDING", "CHANGES_REQUESTED", "APPROVED", "REJECTED", "EXPIRED", "REVOKED"]},
    "decision_rationale": {"type": ["string", "null"]},
    "protocol_version": {"type": ["string", "null"]},
    "evidence_version": {"type": ["string", "null"]},
    "decision_at": {"type": ["string", "null"], "format": "date"},
    "valid_from": {"type": ["string", "null"], "format": "date"},
    "valid_until": {"type": ["string", "null"], "format": "date"},
    "constraints": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "notes": {"type": ["string", "null"]},
    "version": {"type": "string", "minLength": 1},
    "status": {"enum": ["ACTIVE", "RETIRED"]}
  }
}
