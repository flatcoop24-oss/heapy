{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heapy.local/schemas/screening-chunk-evidence.schema.json",
  "title": "건강검진 청크 내부 provenance 레지스트리",
  "description": "공유용 청크에서 분리해 관리하는 근거 문서 레지스트리",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "label",
    "source_url",
    "source_kind",
    "locator_hint",
    "locator_status",
    "review_status",
    "version",
    "status"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "label": {
      "type": "string",
      "minLength": 2
    },
    "source_url": {
      "type": "string",
      "pattern": "^https://"
    },
    "source_kind": {
      "type": "string",
      "enum": [
        "OFFICIAL_RULE",
        "PUBLIC_HEALTH_GUIDANCE",
        "CLINICAL_GUIDELINE"
      ]
    },
    "locator_hint": {
      "type": [
        "string",
        "null"
      ]
    },
    "locator_status": {
      "type": "string",
      "enum": [
        "PENDING_STANDARDIZATION",
        "STANDARDIZED"
      ]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "SOURCE_VERIFIED",
        "REJECTED"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "ACTIVE",
        "RETIRED",
        "REJECTED"
      ]
    }
  }
}
