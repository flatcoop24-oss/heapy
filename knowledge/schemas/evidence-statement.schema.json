{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heapy.local/schemas/evidence-statement.schema.json",
  "title": "Health Guidance Evidence Statement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "source_id",
    "domain",
    "topic",
    "population",
    "statement_type",
    "normalized_statement",
    "allowed_use",
    "prohibited_use",
    "source_locator",
    "keywords",
    "medical_interpretation_required",
    "embed",
    "review_status",
    "version",
    "status"
  ],
  "properties": {
    "evidence_id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
    "source_id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
    "domain": {"enum": ["COMMON", "EXERCISE", "SCREENING", "MEDICATION"]},
    "topic": {"type": "string", "minLength": 1},
    "population": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "statement_type": {"enum": ["EDUCATION", "RECOMMENDATION", "SCOPE", "DATA_CONTRACT", "SOURCE_SCOPE", "CLINICAL_RULE_RATIONALE", "SAFETY_CRITERION"]},
    "normalized_statement": {"type": "string", "minLength": 20},
    "plain_explanation": {"type": ["string", "null"]},
    "allowed_use": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "prohibited_use": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "source_locator": {"type": "string", "minLength": 1},
    "keywords": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "medical_interpretation_required": {"type": "boolean"},
    "embed": {"type": "boolean"},
    "review_status": {"enum": ["DRAFT", "SOURCE_VERIFIED", "READY_FOR_CLINICAL_REVIEW", "CLINICALLY_APPROVED", "REJECTED"]},
    "version": {"type": "string", "minLength": 1},
    "status": {"enum": ["ACTIVE", "DEFERRED", "RETIRED", "REJECTED"]}
  }
}
