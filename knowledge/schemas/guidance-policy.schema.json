{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heapy.local/schemas/guidance-policy.schema.json",
  "title": "Health Guidance Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id",
    "capability_id",
    "domain",
    "intent",
    "risk_level",
    "priority",
    "condition",
    "required_context",
    "action",
    "allowed_claims",
    "prohibited_claims",
    "evidence_ids",
    "source_ids",
    "response_template_id",
    "activation_gate",
    "review_status",
    "version",
    "status"
  ],
  "properties": {
    "policy_id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
    "capability_id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
    "domain": {"enum": ["COMMON", "EXERCISE", "SCREENING", "MEDICATION"]},
    "intent": {"type": "string", "minLength": 1},
    "risk_level": {"enum": ["LOW", "MODERATE", "HIGH", "CRITICAL"]},
    "priority": {"type": "integer", "minimum": 0, "maximum": 1000},
    "condition": {"type": "object", "minProperties": 1},
    "required_context": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "action": {
      "enum": [
        "ANSWER_GENERAL",
        "ASK_CONTEXT",
        "DISPLAY_RECORDED_DATA",
        "EXPLAIN_OFFICIAL_INFORMATION",
        "PROVIDE_CLINICAL_ASSESSMENT",
        "PROVIDE_TREATMENT_GUIDANCE",
        "PROVIDE_CONDITION_SPECIFIC_PLAN",
        "PROVIDE_MEDICATION_GUIDANCE",
        "CLINICAL_REVIEW_REQUIRED",
        "INSUFFICIENT_EVIDENCE",
        "SAFETY_ESCALATION"
      ]
    },
    "allowed_claims": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "prohibited_claims": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "evidence_ids": {"type": "array", "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}, "uniqueItems": true},
    "source_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}, "uniqueItems": true},
    "response_template_id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
    "activation_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clinical_approval_required", "required_review_status", "protocol_version_required", "fail_action"],
      "properties": {
        "clinical_approval_required": {"type": "boolean"},
        "required_review_status": {"enum": ["SOURCE_VERIFIED", "CLINICALLY_APPROVED"]},
        "protocol_version_required": {"type": "boolean"},
        "fail_action": {"enum": ["ASK_CONTEXT", "CLINICAL_REVIEW_REQUIRED", "INSUFFICIENT_EVIDENCE", "SAFETY_ESCALATION"]}
      }
    },
    "notes": {"type": ["string", "null"]},
    "review_status": {"enum": ["DRAFT", "SOURCE_VERIFIED", "READY_FOR_CLINICAL_REVIEW", "CLINICALLY_APPROVED", "REJECTED"]},
    "version": {"type": "string", "minLength": 1},
    "status": {"enum": ["ACTIVE", "DEFERRED", "RETIRED", "REJECTED"]}
  }
}
