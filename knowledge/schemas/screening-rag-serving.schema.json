{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heapy.local/schemas/screening-rag-serving.schema.json",
  "title": "건강검진 RAG Serving Chunk",
  "description": "승인된 Authoring Chunk에서 자동 생성하는 최소 RAG 적재 레코드",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "chunk_id",
    "text",
    "text_sha256",
    "metadata"
  ],
  "properties": {
    "chunk_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "text": {
      "type": "string",
      "minLength": 80
    },
    "text_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_codes",
        "domain",
        "safety_level",
        "evidence_ids",
        "version"
      ],
      "properties": {
        "item_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          }
        },
        "domain": {
          "type": "string",
          "enum": [
            "HEMATOLOGY",
            "GLUCOSE_METABOLISM",
            "LIPID",
            "LIVER",
            "KIDNEY",
            "INFECTIOUS_DISEASE"
          ]
        },
        "safety_level": {
          "type": "string",
          "enum": [
            "LOW",
            "MODERATE",
            "HIGH"
          ]
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          }
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    }
  }
}
